# this script is generated by ai
FROM archlinux:latest AS builder

RUN pacman -Syu --noconfirm && \
      pacman -S --noconfirm \
      base-devel \
      cmake \
      ninja \
      git

WORKDIR /app
COPY . .

RUN rm -rf build && \
  cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DGGML_VULKAN=OFF -DGGML_CLBLAST=OFF && \
  cmake --build build

  FROM archlinux:latest

  WORKDIR /app

  COPY --from=builder /app/build/engine ./engine

  COPY models ./models

  ENTRYPOINT ["./engine a"]

